# ============================================================
# Enterprise Knowledge Hub — .gitignore
# ============================================================

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/

# ── Virtual Environments ────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Node / Frontend ─────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
frontend/dist/
frontend/build/
.next/
.nuxt/
.output/
.vercel/

# ── Environment Files ───────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.staging
!.env.example

# ── Docker ───────────────────────────────────────────────────
docker/volumes/
*.tar
docker-compose.override.yml

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ── Database ─────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Secrets / Keys ───────────────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.jks
secrets/

# ── Temporary Files ─────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig

# ── Coverage & Test Reports ─────────────────────────────────
coverage/
.nyc_output/
test-results/
junit.xml
